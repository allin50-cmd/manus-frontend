{
  "name": "vaultline-brand-suite",
  "version": "1.0.0",
  "description": "VaultLine Brand Suite - Landing pages for VaultLine Cloud, UltAi Secure Intake, and FineGuard Compliance Cloud",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -n \"server,vite\" -c \"blue,green\" \"npm run server:watch\" \"npm run dev\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "node dist/index.js",
    "server": "tsx server/index.ts",
    "server:watch": "tsx watch server/index.ts",
    "db:generate": "drizzle-kit generate:pg",
    "db:push": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "tsx server/db/migrate.ts",
    "db:seed": "tsx server/db/seed.ts",
    "db:generate:clerkos": "drizzle-kit generate:pg --config=drizzle.clerkos.config.ts",
    "db:migrate:clerkos": "tsx server/drizzle/migrate.ts",
    "db:push:clerkos": "drizzle-kit push:pg --config=drizzle.clerkos.config.ts",
    "db:seed:clerkos": "tsx server/drizzle/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "type-check:server": "tsc -p server/tsconfig.json --noEmit",
    "db:bootstrap": "npm run db:migrate:clerkos && npm run db:migrate && npm run db:seed:clerkos"
  },
  "dependencies": {
    "@azure/service-bus": "^7.9.5",
    "@azure/storage-blob": "^12.31.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^4.44.0",
    "@trpc/client": "^10.45.4",
    "@trpc/react-query": "^10.45.4",
    "@trpc/server": "^10.45.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "drizzle-orm": "^0.45.2",
    "express": "^4.18.2",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "node-fetch": "^3.3.2",
    "postgres": "^3.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.0",
    "sonner": "^2.0.7",
    "stripe": "^14.21.0",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.7.0",
    "wouter": "^3.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.2.2",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.12"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
