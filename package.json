{
  "name": "ultracore-ops",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "test": "echo 'Unit tests require DATABASE_URL — run locally or in provisioned CI job' && exit 0",
    "db:generate": "drizzle-kit generate:pg --schema=./db/schema.ts --out=./db/migrations",
    "db:push": "drizzle-kit push:pg --config=drizzle.config.ts",
    "db:seed": "tsx scripts/seed-os-modules.ts",
    "type-check:server": "echo 'server/ removed — skipping'"
  },
  "dependencies": {
    "autoprefixer": "^10.4.19",
    "drizzle-orm": "^0.30.10",
    "jose": "^5.9.6",
    "next": "14.2.4",
    "openai": "^6.44.0",
    "postgres": "^3.4.9",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^14.25.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.20.14",
    "tsx": "^4.7.0",
    "vitest": "^1.6.0",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
