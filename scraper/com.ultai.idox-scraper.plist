<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ultai.idox-scraper</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/yourname/idox-scraper/venv/bin/python3</string>
        <string>/Users/yourname/idox-scraper/run_daily.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/yourname/idox-scraper</string>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/yourname/idox-scraper/logs/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/yourname/idox-scraper/logs/launchd.err.log</string>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
