{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fineguard.io/schemas/webhook-payload.json",
  "title": "FineGuard Webhook Payload",
  "description": "Schema for webhook payloads sent from FineGuard to Azure Function / Power Automate",
  "type": "object",
  "required": ["eventType", "firmId", "timestamp"],
  "properties": {
    "eventType": {
      "type": "string",
      "enum": [
        "filing_due",
        "risk_alert",
        "audit_finding",
        "policy_breach",
        "deadline_reminder"
      ],
      "description": "Type of compliance event"
    },
    "firmId": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for the firm/tenant"
    },
    "firmName": {
      "type": "string",
      "description": "Display name of the firm"
    },
    "riskLevel": {
      "type": "string",
      "enum": ["Low", "Medium", "High", "Critical"],
      "description": "Risk severity level"
    },
    "title": {
      "type": "string",
      "maxLength": 500,
      "description": "Short title for the event"
    },
    "description": {
      "type": "string",
      "maxLength": 5000,
      "description": "Detailed description"
    },
    "dueDate": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 deadline"
    },
    "assignedTo": {
      "type": "string",
      "format": "email",
      "description": "Email of the assigned user"
    },
    "metadata": {
      "type": "object",
      "description": "Arbitrary extra data"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of event creation"
    }
  },
  "additionalProperties": false
}
