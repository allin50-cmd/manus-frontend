{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.16/MicrosoftTeams.schema.json",
  "manifestVersion": "1.16",
  "version": "1.0.0",
  "id": "{{MICROSOFT_APP_ID}}",
  "developer": {
    "name": "FineGuard Compliance Cloud",
    "websiteUrl": "https://fineguard.io",
    "privacyUrl": "https://fineguard.io/privacy",
    "termsOfUseUrl": "https://fineguard.io/terms"
  },
  "name": {
    "short": "FineGuard",
    "full": "FineGuard Compliance Cloud"
  },
  "description": {
    "short": "Real-time compliance monitoring and risk alerts",
    "full": "FineGuard Compliance Cloud delivers real-time compliance monitoring, risk scoring, filing deadline tracking, and automated alerts directly in Microsoft Teams. Stay on top of regulatory obligations without leaving your workflow."
  },
  "icons": {
    "outline": "icon-outline.png",
    "color": "icon-color.png"
  },
  "accentColor": "#1E40AF",
  "staticTabs": [
    {
      "entityId": "fineguard-dashboard",
      "name": "Dashboard",
      "contentUrl": "https://{{APP_DOMAIN}}/teams/tab?page=dashboard",
      "websiteUrl": "https://{{APP_DOMAIN}}/dashboard",
      "scopes": ["personal", "team"]
    },
    {
      "entityId": "fineguard-risk-alerts",
      "name": "Risk Alerts",
      "contentUrl": "https://{{APP_DOMAIN}}/teams/tab?page=risk-alerts",
      "websiteUrl": "https://{{APP_DOMAIN}}/risk-alerts",
      "scopes": ["personal", "team"]
    },
    {
      "entityId": "fineguard-filings",
      "name": "Filing Deadlines",
      "contentUrl": "https://{{APP_DOMAIN}}/teams/tab?page=filings",
      "websiteUrl": "https://{{APP_DOMAIN}}/filings",
      "scopes": ["personal", "team"]
    }
  ],
  "configurableTabs": [
    {
      "configurationUrl": "https://{{APP_DOMAIN}}/teams/tab-config",
      "canUpdateConfiguration": true,
      "scopes": ["team", "groupchat"]
    }
  ],
  "bots": [
    {
      "botId": "{{MICROSOFT_APP_ID}}",
      "scopes": ["personal", "team", "groupchat"],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["personal", "team"],
          "commands": [
            {
              "title": "risk-summary",
              "description": "Show current risk summary for your firm"
            },
            {
              "title": "upcoming-filings",
              "description": "List upcoming filing deadlines"
            },
            {
              "title": "alerts",
              "description": "Show recent compliance alerts"
            },
            {
              "title": "help",
              "description": "Show available commands"
            }
          ]
        }
      ]
    }
  ],
  "composeExtensions": [],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["{{APP_DOMAIN}}", "*.fineguard.io"],
  "webApplicationInfo": {
    "id": "{{MICROSOFT_APP_ID}}",
    "resource": "api://{{APP_DOMAIN}}/{{MICROSOFT_APP_ID}}"
  }
}
