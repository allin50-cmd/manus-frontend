{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noFallthroughCasesInSwitch": true,
    "useUnknownInCatchVariables": true,
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": ["server"],
  "exclude": ["node_modules", "server/**/*.test.ts"]
}
