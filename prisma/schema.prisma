generator client {
  provider      = "prisma-client-js"
  // Vercel may run functions on either x86 (rhel-openssl-3.0.x) or ARM/Graviton
  // (linux-arm64-openssl-3.0.x). With the prebuilt deploy flow, `prisma generate`
  // runs locally, so every runtime we might land on must be listed here or the
  // query engine binary won't be bundled. "native" covers local dev/build.
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum WorkItemType {
  Partnership
  ConstructionLead
  PlanningLead
  ComplianceAlert
  DocumentRecord
  MediaBrief
  InternalTask
  Operations
  TechTask
  Other
}

enum WorkItemStatus {
  Captured
  Controlled
  InProgress
  Waiting
  FollowUpDue
  Escalated
  DecisionNeeded
  Completed
  Paused
  NotFit
  Archived
}

enum Priority {
  Low
  Medium
  High
  Urgent
}

enum ActionType {
  LogNote
  CreateFollowUp
  ChangeStatus
  DraftMessage
  EscalateToGeorge
  GenerateDocument
  MarkComplete
  Archive
  Other
}

enum ActionStatus {
  Open
  Done
  Cancelled
  Blocked
}

enum EventType {
  Created
  NoteAdded
  StatusChanged
  ActionCreated
  ActionCompleted
  DecisionRequested
  DecisionMade
  FollowUpSet
  Archived
}

enum DecisionStatus {
  Open
  Approved
  Rejected
  MoreInfoNeeded
  Paused
}

// ── Alert Recipient Workflow ─────────────────────────────────────────────────

enum RecipientRole {
  Director
  Accountant
  CompanySecretary
  Admin
  ComplianceManager
  ExternalAdviser
  Custom
}

enum DeliveryChannel {
  Email
  Dashboard
  Sms
  WhatsApp
}

enum DeliveryStatus {
  Pending
  Sent
  Failed
  Acknowledged
  Escalated
  Suppressed
}

enum AlertEventType {
  RecipientSelected
  RecipientUpdated
  RecipientDeactivated
  RecipientSuppressed
  DeliveryCreated
  DeliverySent
  DeliveryFailed
  AlertAcknowledged
  EscalationTriggered
  EscalationDeliveryCreated
}

// ── CRM / Partnerships pipeline stages ───────────────────────────────────────

enum PipelineStage {
  // Software Integration Partnership
  SIP_Identified
  SIP_Contacted
  SIP_IntroCall
  SIP_Evaluating
  SIP_Negotiating
  SIP_Agreed
  SIP_Live
  SIP_Paused
  SIP_Declined
  // Construction Lead
  CL_NewEnquiry
  CL_Qualified
  CL_Quoting
  CL_QuoteSent
  CL_Negotiating
  CL_Won
  CL_Lost
  CL_OnHold
  // Planning Lead
  PL_Identified
  PL_Research
  PL_Outreach
  PL_ApplicationPrep
  PL_Submitted
  PL_UnderReview
  PL_Approved
  PL_Refused
  PL_OnHold
}

enum OutreachChannel {
  Email
  Phone
  VideoCall
  InPerson
  LinkedIn
  WhatsApp
  Other
}

enum OutreachDirection {
  Outbound
  Inbound
}

// ── Compliance / Filings ──────────────────────────────────────────────────────

enum FilingCategory {
  CONFIRMATION_STATEMENT
  ANNUAL_ACCOUNTS
  VAT_RETURN
  CORPORATION_TAX_RETURN
  PAYE_RTI
  COMPANIES_HOUSE_CHANGE
  INSURANCE_RENEWAL
  CONTRACT_RENEWAL
  REGULATORY_REPORT
  OTHER
}

enum FilingStatus {
  UPCOMING
  AT_RISK
  OVERDUE
  COMPLETED
  EXEMPT
  CANCELLED
}

enum FilingSource {
  MANUAL
  CSV_IMPORT
  COMPANIES_HOUSE
  SYSTEM_GENERATED
}

// ── Templates ─────────────────────────────────────────────────────────────────

enum TemplateCategory {
  ComplianceAlert
  FollowUp
  ClientCommunication
  InternalNote
  StatusUpdate
  General
}

// ── Core models ──────────────────────────────────────────────────────────────

model WorkItem {
  id             String         @id @default(cuid())
  type           WorkItemType
  title          String
  company        String?
  contactName    String?
  owner          String
  status         WorkItemStatus @default(Captured)
  priority       Priority       @default(Medium)
  nextAction     String?
  dueDate        DateTime?
  decisionNeeded Boolean        @default(false)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // CRM / pipeline fields
  companyId     String?
  contactId     String?
  pipelineStage PipelineStage?
  dealValue     Decimal?

  companyRef Company? @relation(fields: [companyId], references: [id])
  contactRef Contact? @relation(fields: [contactId], references: [id])

  actions         Action[]
  activityLogs    ActivityLog[]
  decisions       Decision[]
  alertDeliveries AlertDelivery[]
  alertEvents     AlertEvent[]
  voiceIntakes    VoiceIntake[]
  outreachLogs    OutreachLog[]
  filing          Filing?

  @@index([companyId])
  @@index([contactId])
  @@index([status])
  @@index([owner])
  @@index([type])
}

model Action {
  id          String       @id @default(cuid())
  workItemId  String
  actionType  ActionType
  label       String
  status      ActionStatus @default(Open)
  assignedTo  String?
  dueDate     DateTime?
  result      String?
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  // Handoff / reassignment audit trail
  reassignedFrom String?
  reassignedAt   DateTime?
  reassignedBy   String?
  handoffNote    String?

  workItem     WorkItem      @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  activityLogs ActivityLog[]

  @@index([workItemId])
  @@index([assignedTo])
}

model ActivityLog {
  id           String    @id @default(cuid())
  workItemId   String
  actionId     String?
  person       String
  eventType    EventType
  summary      String
  oldStatus    String?
  newStatus    String?
  evidenceLink String?
  createdAt    DateTime  @default(now())

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  action   Action?  @relation(fields: [actionId], references: [id])

  @@index([workItemId])
  @@index([person])
  @@index([createdAt])
}

model Decision {
  id             String         @id @default(cuid())
  workItemId     String
  question       String
  options        String?
  recommendation String?
  decisionBy     String         @default("George")
  decision       String?
  status         DecisionStatus @default(Open)
  dueDate        DateTime?
  decidedAt      DateTime?
  createdAt      DateTime       @default(now())

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
}

model Template {
  id           String           @id @default(cuid())
  name         String
  useCase      String
  body         String
  approved     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Approval workflow
  category     TemplateCategory @default(General)
  variables    String[]         @default([])
  pendingReview Boolean         @default(false)
  approvedBy   String?
  approvedAt   DateTime?
  reviewNote   String?
}

// ── Alert Recipient models ────────────────────────────────────────────────────

model AlertRecipient {
  id                String          @id @default(cuid())
  company           String
  name              String
  email             String?
  phone             String?
  role              RecipientRole
  preferredChannel  DeliveryChannel @default(Dashboard)
  alertCategories   String[]
  escalationLevel   Int             @default(1)
  isActive          Boolean         @default(true)
  isSuppressed      Boolean         @default(false)
  suppressionReason String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  deliveries  AlertDelivery[]
  alertEvents AlertEvent[]
}

model AlertDelivery {
  id              String          @id @default(cuid())
  workItemId      String
  recipientId     String
  channel         DeliveryChannel
  status          DeliveryStatus  @default(Pending)
  ackToken        String?         @unique
  sentAt          DateTime?
  acknowledgedAt  DateTime?
  failedAt        DateTime?
  failureReason   String?
  escalationLevel Int             @default(1)
  createdAt       DateTime        @default(now())

  workItem    WorkItem       @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  recipient   AlertRecipient @relation(fields: [recipientId], references: [id])
  alertEvents AlertEvent[]
}

model AlertEvent {
  id          String         @id @default(cuid())
  workItemId  String?
  deliveryId  String?
  recipientId String?
  eventType   AlertEventType
  actorType   String
  actorId     String?
  payload     String?
  createdAt   DateTime       @default(now())

  workItem  WorkItem?       @relation(fields: [workItemId], references: [id], onDelete: SetNull)
  delivery  AlertDelivery?  @relation(fields: [deliveryId], references: [id], onDelete: SetNull)
  recipient AlertRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)
}

model UserPassword {
  person    String   @id
  hash      String
  updatedAt DateTime @updatedAt
}

// ── Voice Intake ──────────────────────────────────────────────────────────────

enum VoiceIntakeStatus {
  UPLOADED
  TRANSCRIBED
  NEEDS_REVIEW
  APPROVED
  REJECTED
  FAILED
}

model VoiceIntake {
  id               String            @id @default(cuid())
  createdAt        DateTime          @default(now())
  createdBy        String
  audioData        Bytes?
  mimeType         String            @default("audio/webm")
  transcript       String?
  parsedJson       Json?
  status           VoiceIntakeStatus @default(UPLOADED)
  reviewNotes      String?
  approvedAt       DateTime?
  approvedBy       String?
  linkedWorkItemId String?
  linkedWorkItem   WorkItem?         @relation(fields: [linkedWorkItemId], references: [id], onDelete: SetNull)

  // Quality scoring from Whisper verbose_json
  transcriptConfidence Float?
  qualityFlags         String[] @default([])
}

// ── Contacts & Companies ─────────────────────────────────────────────────────

model Company {
  id                   String    @id @default(cuid())
  name                 String    @unique
  companiesHouseNumber String?   @unique
  incorporationDate    DateTime?
  jurisdiction         String    @default("UK")
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  contacts  Contact[]
  workItems WorkItem[]
  filings   Filing[]
}

model Contact {
  id        String   @id @default(cuid())
  companyId String
  name      String
  role      String?
  email     String?
  phone     String?
  isPrimary Boolean  @default(false)
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id])
  workItems    WorkItem[]
  outreachLogs OutreachLog[]
}

// ── Outreach Log (CRM) ────────────────────────────────────────────────────────

model OutreachLog {
  id           String            @id @default(cuid())
  workItemId   String
  contactId    String?
  contactName  String?
  channel      OutreachChannel
  direction    OutreachDirection
  summary      String
  loggedBy     String
  occurredAt   DateTime
  createdAt    DateTime          @default(now())
  followUpDate DateTime?
  followUpDone Boolean           @default(false)

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  contact  Contact? @relation(fields: [contactId], references: [id])

  @@index([workItemId])
  @@index([contactId])
}

// ── Compliance / Filings ──────────────────────────────────────────────────────

model Filing {
  id                  String        @id @default(cuid())
  companyId           String
  company             Company       @relation(fields: [companyId], references: [id])

  category            FilingCategory
  title               String
  statutoryReference  String?
  description         String?

  dueDate             DateTime
  periodStart         DateTime?
  periodEnd           DateTime?

  isRecurring         Boolean       @default(false)
  recurrenceRule      String?
  parentFilingId      String?
  parentFiling        Filing?       @relation("RecurringInstances", fields: [parentFilingId], references: [id])
  childFilings        Filing[]      @relation("RecurringInstances")

  status              FilingStatus  @default(UPCOMING)
  completedAt         DateTime?
  completedByPerson   String?
  filedReference      String?

  source              FilingSource  @default(MANUAL)
  externalId          String?
  importBatchId       String?

  workItemId          String?       @unique
  workItem            WorkItem?     @relation(fields: [workItemId], references: [id])

  lastReminderSentAt  DateTime?
  reminderCount       Int           @default(0)
  suppressReminders   Boolean       @default(false)

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([companyId, dueDate])
  @@index([status, dueDate])
  @@index([category, companyId])
}

model CsvImportBatch {
  id           String   @id @default(cuid())
  importedBy   String
  filename     String
  rowCount     Int
  successCount Int      @default(0)
  errorCount   Int      @default(0)
  errors       Json?
  createdAt    DateTime @default(now())
}

model CompaniesHousePollLog {
  id             String   @id @default(cuid())
  companyNumber  String
  endpoint       String
  polledAt       DateTime @default(now())
  responseStatus Int
  itemsFound     Int      @default(0)
  itemsCreated   Int      @default(0)
  itemsSkipped   Int      @default(0)
  errorMessage   String?
}

// ── Push Notifications ────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  person    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([person])
}

// ── Digest Log ────────────────────────────────────────────────────────────────

model DigestLog {
  id             String   @id @default(cuid())
  sentAt         DateTime @default(now())
  recipientEmail String
  status         String
  errorMessage   String?
}
