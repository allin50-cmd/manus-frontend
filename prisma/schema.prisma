generator client {
  provider      = "prisma-client-js"
  // Vercel may run functions on either x86 (rhel-openssl-3.0.x) or ARM/Graviton
  // (linux-arm64-openssl-3.0.x). With the prebuilt deploy flow, `prisma generate`
  // runs locally, so every runtime we might land on must be listed here or the
  // query engine binary won't be bundled. "native" covers local dev/build.
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum WorkItemType {
  Partnership
  ConstructionLead
  PlanningLead
  ComplianceAlert
  DocumentRecord
  MediaBrief
  InternalTask
  Operations
  TechTask
  Other
}

enum WorkItemStatus {
  Captured
  Controlled
  InProgress
  Waiting
  FollowUpDue
  Escalated
  DecisionNeeded
  Completed
  Paused
  NotFit
  Archived
}

enum Priority {
  Low
  Medium
  High
  Urgent
}

enum ActionType {
  LogNote
  CreateFollowUp
  ChangeStatus
  DraftMessage
  EscalateToGeorge
  GenerateDocument
  MarkComplete
  Archive
  Other
}

enum ActionStatus {
  Open
  Done
  Cancelled
  Blocked
}

enum EventType {
  Created
  NoteAdded
  StatusChanged
  ActionCreated
  ActionCompleted
  DecisionRequested
  DecisionMade
  FollowUpSet
  Archived
}

enum DecisionStatus {
  Open
  Approved
  Rejected
  MoreInfoNeeded
  Paused
}

// ── Alert Recipient Workflow ─────────────────────────────────────────────────

enum RecipientRole {
  Director
  Accountant
  CompanySecretary
  Admin
  ComplianceManager
  ExternalAdviser
  Custom
}

enum DeliveryChannel {
  Email
  Dashboard
  Sms
  WhatsApp
}

enum DeliveryStatus {
  Pending
  Sent
  Failed
  Acknowledged
  Escalated
  Suppressed
}

enum AlertEventType {
  RecipientSelected
  RecipientUpdated
  RecipientDeactivated
  RecipientSuppressed
  DeliveryCreated
  DeliverySent
  DeliveryFailed
  AlertAcknowledged
  EscalationTriggered
  EscalationDeliveryCreated
}

// ── Core models ──────────────────────────────────────────────────────────────

model WorkItem {
  id             String         @id @default(cuid())
  type           WorkItemType
  title          String
  company        String?
  contactName    String?
  owner          String
  status         WorkItemStatus @default(Captured)
  priority       Priority       @default(Medium)
  nextAction     String?
  dueDate        DateTime?
  decisionNeeded Boolean        @default(false)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  actions         Action[]
  activityLogs    ActivityLog[]
  decisions       Decision[]
  alertDeliveries AlertDelivery[]
  alertEvents     AlertEvent[]
  voiceIntakes    VoiceIntake[]
}

model Action {
  id             String       @id @default(cuid())
  workItemId     String
  actionType     ActionType
  label          String
  status         ActionStatus @default(Open)
  assignedTo     String?
  dueDate        DateTime?
  result         String?
  reassignedFrom String?
  reassignedAt   DateTime?
  reassignedBy   String?
  handoffNote    String?
  createdAt      DateTime     @default(now())
  completedAt    DateTime?

  workItem     WorkItem      @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  activityLogs ActivityLog[]
}

model ActivityLog {
  id           String    @id @default(cuid())
  workItemId   String
  actionId     String?
  person       String
  eventType    EventType
  summary      String
  oldStatus    String?
  newStatus    String?
  evidenceLink String?
  createdAt    DateTime  @default(now())

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  action   Action?  @relation(fields: [actionId], references: [id])
}

model Decision {
  id             String         @id @default(cuid())
  workItemId     String
  question       String
  options        String?
  recommendation String?
  decisionBy     String         @default("George")
  decision       String?
  status         DecisionStatus @default(Open)
  dueDate        DateTime?
  decidedAt      DateTime?
  createdAt      DateTime       @default(now())

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
}

model Template {
  id        String   @id @default(cuid())
  name      String
  useCase   String
  body      String
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Alert Recipient models ────────────────────────────────────────────────────

model AlertRecipient {
  id                String          @id @default(cuid())
  company           String
  name              String
  email             String?
  phone             String?
  role              RecipientRole
  preferredChannel  DeliveryChannel @default(Dashboard)
  alertCategories   String[]
  escalationLevel   Int             @default(1)
  isActive          Boolean         @default(true)
  isSuppressed      Boolean         @default(false)
  suppressionReason String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  deliveries  AlertDelivery[]
  alertEvents AlertEvent[]
}

model AlertDelivery {
  id              String          @id @default(cuid())
  workItemId      String
  recipientId     String
  channel         DeliveryChannel
  status          DeliveryStatus  @default(Pending)
  ackToken        String?         @unique
  sentAt          DateTime?
  acknowledgedAt  DateTime?
  failedAt        DateTime?
  failureReason   String?
  escalationLevel Int             @default(1)
  createdAt       DateTime        @default(now())

  workItem    WorkItem       @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  recipient   AlertRecipient @relation(fields: [recipientId], references: [id])
  alertEvents AlertEvent[]
}

model AlertEvent {
  id          String         @id @default(cuid())
  workItemId  String?
  deliveryId  String?
  recipientId String?
  eventType   AlertEventType
  actorType   String
  actorId     String?
  payload     String?
  createdAt   DateTime       @default(now())

  workItem  WorkItem?       @relation(fields: [workItemId], references: [id], onDelete: SetNull)
  delivery  AlertDelivery?  @relation(fields: [deliveryId], references: [id], onDelete: SetNull)
  recipient AlertRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)
}

model UserPassword {
  person    String   @id
  hash      String
  updatedAt DateTime @updatedAt
}

// ── Voice Intake ──────────────────────────────────────────────────────────────

enum VoiceIntakeStatus {
  UPLOADED
  TRANSCRIBED
  NEEDS_REVIEW
  APPROVED
  REJECTED
  FAILED
}

model VoiceIntake {
  id                   String            @id @default(cuid())
  createdAt            DateTime          @default(now())
  createdBy            String
  audioData            Bytes?
  mimeType             String            @default("audio/webm")
  transcript           String?
  transcriptConfidence Float?
  qualityFlags         String[]          @default([])
  parsedJson           Json?
  status               VoiceIntakeStatus @default(UPLOADED)
  reviewNotes          String?
  approvedAt           DateTime?
  approvedBy           String?
  linkedWorkItemId     String?
  linkedWorkItem       WorkItem?         @relation(fields: [linkedWorkItemId], references: [id], onDelete: SetNull)
}

// ── Contacts & Companies ─────────────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts Contact[]
}

model Contact {
  id        String   @id @default(cuid())
  companyId String
  name      String
  role      String?
  email     String?
  phone     String?
  isPrimary Boolean  @default(false)
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}
