{
  "backend": {
    "runtime": "Azure Functions v4",
    "language": "TypeScript (ESM)",
    "telemetry": "Application Insights Node SDK",

    "endpoints": [
      { "method": "GET",  "path": "/api/me",                     "description": "Current authenticated user" },
      { "method": "POST", "path": "/api/deploy",                  "description": "Start a new deployment run" },
      { "method": "GET",  "path": "/api/logs",                    "description": "Stream logs for a run" },
      { "method": "GET",  "path": "/api/runs",                    "description": "List deployment runs" },
      { "method": "GET",  "path": "/api/runById",                 "description": "Fetch a single run by ID" },
      { "method": "GET",  "path": "/api/settings",                "description": "Get all settings for the owner" },
      { "method": "POST", "path": "/api/settings/domains",        "description": "Save domain config" },
      { "method": "POST", "path": "/api/settings/copilot",        "description": "Save Copilot / Azure OpenAI config" },
      { "method": "POST", "path": "/api/settings/teams",          "description": "Save Teams channel config" },
      { "method": "POST", "path": "/api/settings/power-automate", "description": "Save Power Automate flow toggles" },
      { "method": "GET",  "path": "/api/overview",                "description": "Partner-level practice overview" },
      { "method": "GET",  "path": "/api/overviewByTenant",        "description": "Single-tenant deadline and risk overview" }
    ],

    "database": {
      "provider": "Azure Cosmos DB (SQL API)",
      "database": "FineGuard",
      "containers": [
        {
          "name": "Deployments",
          "partitionKey": "/ownerId",
          "schema": {
            "id": "string (uuid)",
            "ownerId": "string (Entra OID)",
            "tenantName": "string",
            "tenantEmail": "string",
            "createdAt": "ISO8601",
            "status": "Running | Success | Failed",
            "runtimeEndpoint": "string",
            "config": {
              "sharePointDomain": "string",
              "functionsDomain": "string"
            },
            "steps": [
              {
                "name": "string",
                "status": "Pending | Running | Success | Failed",
                "startedAt": "ISO8601 | null",
                "completedAt": "ISO8601 | null",
                "message": "string | null"
              }
            ],
            "logs": ["string"]
          }
        },
        {
          "name": "Settings",
          "partitionKey": "/ownerId",
          "schema": {
            "id": "string (uuid)",
            "ownerId": "string (Entra OID)",
            "domains": {
              "sharePointDomain": "string",
              "functionsDomain": "string"
            },
            "copilot": {
              "enabled": "boolean",
              "endpoint": "string",
              "deploymentName": "string"
            },
            "teams": {
              "channelName": "string",
              "webhookUrl": "string",
              "mentionEnabled": "boolean"
            },
            "powerAutomate": {
              "deadlineReminders": "boolean",
              "clientOnboarding": "boolean",
              "documentApprovals": "boolean",
              "complianceAlerts": "boolean"
            },
            "updatedAt": "ISO8601"
          }
        }
      ]
    },

    "authentication": {
      "provider": "Microsoft Entra ID (via SWA built-in auth)",
      "header": "x-ms-client-principal",
      "tokenFormat": "base64-encoded JSON"
    }
  }
}
