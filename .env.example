# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Azure Flexible Server: Settings → Connection strings → copy and replace {password}
# Local (docker compose up -d postgres):
DATABASE_URL=postgres://vaultline:<password>@<host>:5432/vaultline

# ─── Companies House ─────────────────────────────────────────────────────────
# Required for FineGuard real-time company compliance checking.
# Free registration: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=

# ─── Stripe ──────────────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API keys
# Use sk_test_* for staging, sk_live_* for production.
STRIPE_SECRET_KEY=
# dashboard.stripe.com → Developers → Webhooks → Add endpoint
# Endpoint URL: https://<your-domain>/api/stripe/webhook
# Events to listen for: checkout.session.completed
STRIPE_WEBHOOK_SECRET=
# dashboard.stripe.com → Product catalogue → FineGuard plan → Price ID
STRIPE_PRICE_ID=

# ─── App ─────────────────────────────────────────────────────────────────────
# Public URL of the frontend (used in Stripe redirect URLs).
APP_URL=https://your-swa.azurestaticapps.net

# ─── Auth ────────────────────────────────────────────────────────────────────
# Shared secret for admin panel login and CI deployment recording.
# Generate: openssl rand -hex 32
DEPLOY_RECORD_TOKEN=

# ─── Server (optional) ───────────────────────────────────────────────────────
PORT=3000
