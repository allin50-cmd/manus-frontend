# Supabase Postgres is the source of truth.
# Use the Transaction pooler URL (port 6543) on Vercel — not direct port 5432.
# Supabase → Settings → Database → Connection Pooling → Transaction mode
DATABASE_URL=

# Simple passcode login for the operator app.
APP_PASSCODE=

# Required. Generate with: openssl rand -hex 32
JWT_SECRET=

# Optional. When set, used as the base URL for Stripe redirect URLs.
# Leave blank on Vercel — the app detects the deployment URL automatically.
# Set this only if you have a custom domain (e.g. https://yourdomain.com).
NEXT_PUBLIC_APP_URL=

# Companies House API. When unset, /api/companies/* fall back to demo data.
# Get a key at https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=

# Stripe. When unset, the /check "Activate" flow falls back to direct
# activation (no payment). Set all three to enable real £4.99/month checkout.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
