# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (sslmode=require for Azure)
DATABASE_URL="postgresql://user:password@localhost:5432/vaultline_db"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Deployment tracking ─────────────────────────────────────────────────────
# Token that GitHub Actions sends in the X-DEPLOY-TOKEN header when recording
# deployments. Generate with: openssl rand -hex 32
DEPLOY_RECORD_TOKEN="your-secure-token-here"

# Base URL of this API server (used in the admin dashboard deployment links)
VAULTLINE_API_URL="https://your-app.azurewebsites.net"

# ─── Companies House API ─────────────────────────────────────────────────────
# Required for FineGuard real-time company compliance checking.
# Free tier: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY="your-companies-house-api-key-here"

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."

# Webhook signing secret — from Stripe Dashboard > Webhooks > your endpoint
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price ID for the FineGuard monitoring subscription (£3/mo)
STRIPE_PRICE_ID="price_..."

# Public URL of the frontend (used for Stripe success/cancel redirect URLs)
APP_URL="https://your-swa.azurestaticapps.net"
