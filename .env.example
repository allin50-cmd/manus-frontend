# ── Database ──────────────────────────────────────────────────────────────────
# Vercel Postgres (or any PostgreSQL provider: Neon, Supabase, Railway, etc.)
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Admin / Security ──────────────────────────────────────────────────────────
# Protects /api/governance, /api/voice-reception, and /api/pie/ingest endpoints.
# Generate: openssl rand -hex 32
ADMIN_API_KEY="your-secure-admin-key-here"

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used by the voice agent AI classifier (GPT-4o).
OPENAI_API_KEY="sk-..."

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PRICE_ID="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_KEY="re_..."
EMAIL_FROM="audit@yourdomain.co.uk"

# ── Companies House API ───────────────────────────────────────────────────────
# Required for FineGuard compliance checks.
# Free key at: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY="your-companies-house-api-key-here"

# ── Zapier Integration ────────────────────────────────────────────────────────
# Authenticates requests to /api/zapier/* endpoints.
# Generate: openssl rand -hex 32
ZAPIER_API_KEY="your-zapier-api-key-here"

# ── PIE Lite pipeline (local use only — not needed on Vercel) ─────────────────
# Set when running: python -m pie_lite.pipeline push
# PIE_API_URL="https://your-app.vercel.app"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=3000
