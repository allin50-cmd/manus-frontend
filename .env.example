# ── Database (Supabase) ───────────────────────────────────────────────────────
# Pooled connection (used by Prisma at runtime via pgBouncer)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (used by Prisma for migrations / db push)
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:5432/postgres

# Supabase admin client (server-side only — never expose to the browser)
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=generate-with--openssl-rand-hex-32

# Shared starting passcode — users enter this to log in
DEFAULT_PASSCODE=choose-a-strong-shared-passcode

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# ── Email (optional) ──────────────────────────────────────────────────────────
# Leave blank to skip real email delivery; alerts still appear in the dashboard
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@yourdomain.com
