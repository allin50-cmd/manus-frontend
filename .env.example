# ── Database ──────────────────────────────────────────────────────────
# Azure Database for PostgreSQL flexible server recommended
# Format: postgresql://username:password@host:5432/database?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/fineguard?sslmode=require"

# ── Stripe ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Create these price IDs in your Stripe dashboard (£1/mo each)
STRIPE_PRICE_ACCOUNTS_FILING="price_..."
STRIPE_PRICE_CONFIRMATION_STATEMENT="price_..."
STRIPE_PRICE_STRIKE_OFF="price_..."

# ── Companies House ───────────────────────────────────────────────────
# Free API key: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY="your-api-key"
COMPANIES_HOUSE_BASE_URL="https://api.company-information.service.gov.uk"

# ── App ───────────────────────────────────────────────────────────────
# PUBLIC_APP_URL: used for Stripe success/cancel redirects (your public domain)
# APP_URL: fallback when PUBLIC_APP_URL is not set (Azure hostname)
PUBLIC_APP_URL="https://fineguardpro.com"
APP_URL="https://fineguardpro.azurewebsites.net"
NEXT_PUBLIC_BASE_URL="https://fineguardpro.azurewebsites.net"
NODE_ENV="production"
PORT=8080
WEBSITES_PORT=8080

# ── Deployment tracking (optional) ────────────────────────────────────
# Generate with: openssl rand -hex 32
DEPLOY_RECORD_TOKEN="your-secure-token-here"
