# ============================================================================
# FineGuard Pro - Environment Variables
# ============================================================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/fineguard_db"

# JWT Authentication Secret - generate: openssl rand -hex 64
JWT_SECRET="your-super-secure-jwt-secret-minimum-32-chars"

# Server
PORT=3000
NODE_ENV=development

# Companies House API
# Get FREE key: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY="your-companies-house-api-key"

# Stripe Billing
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Document Storage (AWS S3)
STORAGE_BASE_URL="https://your-bucket.s3.eu-west-2.amazonaws.com"
AWS_REGION="eu-west-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="fineguard-documents"

# Alert Webhooks (optional)
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."
TEAMS_WEBHOOK_URL="https://yourorg.webhook.office.com/..."

# Deployment Tracking
DEPLOY_RECORD_TOKEN="your-deploy-token-from-openssl-rand-hex-32"
