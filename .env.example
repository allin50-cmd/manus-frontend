# ── Database ──────────────────────────────────────────────────────────────────
# Required. Vercel Postgres, Neon, Supabase, Railway, or any PostgreSQL provider.
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── App URL ───────────────────────────────────────────────────────────────────
# Required in production for absolute links such as Stripe checkout redirects and emails.
# Use your primary Vercel production domain, for example: https://your-app.vercel.app
APP_URL="https://your-app.vercel.app"

# ── Admin / Security ──────────────────────────────────────────────────────────
# Protects /api/governance, /api/voice-reception, /api/companies, /api/alerts,
# and /api/pie/ingest endpoints. Generate: openssl rand -hex 32
ADMIN_API_KEY="your-secure-admin-key-here"

# Used by /api/deployments/record via the x-deploy-token header.
# Keep this if GitHub Actions or deploy scripts record deployment status.
# Generate: openssl rand -hex 32
DEPLOY_RECORD_TOKEN="your-secure-deploy-record-token-here"

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used by the sales agent and voice-reception AI classifier. If omitted, voice
# classification falls back to deterministic keyword matching, but sales-agent
# routes that call OpenAI require this.
OPENAI_API_KEY="sk-..."

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PRICE_ID="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Email (Resend) ────────────────────────────────────────────────────────────
# If RESEND_KEY is omitted, email sending is skipped.
RESEND_KEY="re_..."
EMAIL_FROM="audit@yourdomain.co.uk"

# ── Companies House API ───────────────────────────────────────────────────────
# Required for FineGuard compliance checks.
# Free key at: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY="your-companies-house-api-key-here"

# ── Zapier Integration ────────────────────────────────────────────────────────
# Authenticates requests to /api/zapier/* endpoints. Generate: openssl rand -hex 32
ZAPIER_API_KEY="your-zapier-api-key-here"

# ── PIE Lite pipeline (local use only — not needed on Vercel) ─────────────────
# Set when running: python -m pie_lite.pipeline push
# PIE_API_URL="https://your-app.vercel.app"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="production"
# PORT is not required on Vercel; Vercel manages the serverless runtime port.
# PORT=3000
