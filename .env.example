# ============================================================================
# VaultLine Brand Suite – Environment Variables
# Copy to .env and fill in values for local development.
# In Azure App Service, set these as Application Settings.
# ============================================================================

# ---------- DATABASE ----------
# PostgreSQL connection string
# Local:  postgresql://vaultline:vaultline_dev@localhost:5432/vaultline_db
# Azure:  postgresql://user:password@<server>.postgres.database.azure.com:5432/vaultline_db?sslmode=require
DATABASE_URL="postgresql://vaultline:vaultline_dev@localhost:5432/vaultline_db"

# ---------- SERVER ----------
PORT=3000
NODE_ENV=development            # Set to "production" in Azure App Settings

# ---------- AUTH ----------
# Deployment recording token (GitHub Actions → /api/deployments/record)
# Generate with: openssl rand -hex 32
DEPLOY_RECORD_TOKEN="your-secure-token-here"

# ---------- COMPANIES HOUSE ----------
# Free API key from https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY="your-companies-house-api-key-here"

# ============================================================================
# MICROSOFT 365 INTEGRATION (Optional)
# ============================================================================
# Enable Teams, Outlook, SharePoint, and Power Automate integration.
# Leave blank to skip M365 features (graceful degradation).

# Azure AD Configuration
# 1. Register app: https://portal.azure.com → Azure Active Directory → App registrations → New registration
# 2. Get credentials: Certificates & secrets → Create new client secret
# 3. Grant permissions: API permissions → Microsoft Graph → Mail.Send, Calendars.ReadWrite, ChannelMessage.Send, User.Read.All
AZURE_TENANT_ID="your-azure-tenant-id-here"
AZURE_CLIENT_ID="your-azure-client-id-here"
AZURE_CLIENT_SECRET="your-azure-client-secret-here"
AZURE_REDIRECT_URI="http://localhost:3000/auth/callback"
AZURE_SCOPES="https://graph.microsoft.com/.default"

# Outlook Integration (Optional)
# Service account email for sending notifications
OUTLOOK_SENDER_USER_ID="fineguard@yourdomain.com"

# Teams Integration (Optional)
# Team and channel IDs for compliance alert delivery
TEAMS_TEAM_ID="your-teams-team-id"
TEAMS_CHANNEL_ID="your-teams-channel-id"
MICROSOFT_APP_ID="same-as-AZURE_CLIENT_ID"
MICROSOFT_APP_PASSWORD="same-as-AZURE_CLIENT_SECRET"

# Webhook Configuration (Optional)
# For Azure Function → Power Automate integration
FINEGUARD_WEBHOOK_SECRET="$(openssl rand -hex 32)"
AZURE_FUNCTION_URL="https://your-function-app.azurewebsites.net/api/fineGuardWebhook"
POWER_AUTOMATE_TRIGGER_URL="https://prod-123.eastus.logic.azure.com/workflows/123/triggers/manual/paths/invoke?api-version=2016-06-01&sp=..."
FINEGUARD_APP_URL="http://localhost:5173"
FINEGUARD_API_URL="http://localhost:3000"

# Service token for Teams Bot API calls (generate with: openssl rand -hex 48)
# Create a long-lived session token for the bot to use when calling FineGuard API
FINEGUARD_SERVICE_TOKEN=""

# ============================================================================
# These are set as GitHub repository/environment secrets, NOT in .env.
#
# Required secrets for the CI/CD pipeline:
#
#   ACR_LOGIN_SERVER        Azure Container Registry login server
#                           e.g. vaultlineacr.azurecr.io
#
#   ACR_USERNAME            ACR admin username or service principal
#
#   ACR_PASSWORD            ACR admin password or service principal secret
#
#   AZURE_CREDENTIALS       Service principal JSON for azure/login
#                           az ad sp create-for-rbac --name "vaultline-cicd" \
#                             --role contributor --scopes /subscriptions/<sub-id>
#
#   AZURE_WEBAPP_NAME_DEV   App Service name (dev)    e.g. vaultline-dev
#   AZURE_WEBAPP_NAME_STAGING  App Service name (staging) e.g. vaultline-staging
#   AZURE_WEBAPP_NAME_PROD  App Service name (prod)   e.g. vaultline-prod
#
#   VAULTLINE_API_URL       Base URL for deployment recording
#                           e.g. https://vaultline-prod.azurewebsites.net
#
#   DEPLOY_RECORD_TOKEN     Same token as above, set as secret in GitHub
#
#   AZURE_STATIC_WEB_APPS_API_TOKEN   For PR preview deployments (optional)
# ============================================================================
