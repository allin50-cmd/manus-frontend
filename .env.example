# Supabase Postgres is the source of truth.
# Use the Supabase connection string in Vercel and locally.
DATABASE_URL=

# Simple passcode login for the operator app.
APP_PASSCODE=

# Required. Generate with: openssl rand -hex 32
JWT_SECRET=

# Public app/domain metadata used for deployment notes and future redirects.
NEXT_PUBLIC_APP_URL=https://fineguardpro.com
NEXT_PUBLIC_PRIMARY_DOMAIN=fineguardpro.com

# Companies House API. When unset, /api/companies/* fall back to demo data.
# Get a key at https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=

# Stripe. When unset, the /check "Activate" flow falls back to direct
# activation (no payment). Set all three to enable real £1/month checkout.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
