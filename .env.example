# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Leave unset to run ClerkOS in demo mode (mock data).
DATABASE_URL=postgresql://user:password@localhost:5432/clerkos

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Multi-tenancy ────────────────────────────────────────────────────────────
# Fallback tenant slug when no subdomain or x-tenant header is present.
DEFAULT_TENANT_SLUG=alpha

# ─── Azure AD B2C ─────────────────────────────────────────────────────────────
# Required for production JWT validation. Leave unset to use x-user-open-id dev header.
AZURE_B2C_TENANT_NAME=yourtenantname
AZURE_B2C_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_B2C_POLICY=B2C_1_signupsignin
AZURE_B2C_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Azure Blob Storage ───────────────────────────────────────────────────────
# Required for document upload and bundle PDF generation.
AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount
AZURE_STORAGE_ACCOUNT_KEY=your-storage-key
AZURE_STORAGE_CONTAINER=clerkos-documents
AZURE_STORAGE_SAS_EXPIRY_MINUTES=60

# ─── Azure Service Bus ────────────────────────────────────────────────────────
# Required for async bundle generation queue.
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://...

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000

# Owner open-id gets admin role automatically on first sign-in.
OWNER_OPEN_ID=admin-user

# ─── Deployment tracking ──────────────────────────────────────────────────────
DEPLOY_RECORD_TOKEN=your-deploy-token

# ─── Stripe (VaultLine marketplace features) ──────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
COMPANIES_HOUSE_API_KEY=your-companies-house-api-key
