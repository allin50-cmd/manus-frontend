# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Companies House API ──────────────────────────────────────────────────────
# Get a free API key at: https://developer.company-information.service.gov.uk/
# Without a key, the server uses mock data — useful for local development.
COMPANIES_HOUSE_API_KEY=your-companies-house-api-key-here

# ─── Database (optional) ─────────────────────────────────────────────────────
# Without DATABASE_URL, the server uses an in-memory store.
# Data resets on restart. For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/fineguard?sslmode=require

# ─── Alert Sweep ─────────────────────────────────────────────────────────────
# How often to check monitored companies for new alerts (hours). Default: 6.
SWEEP_INTERVAL_HOURS=6

# ─── Legacy ───────────────────────────────────────────────────────────────────
# Used by GitHub Actions CI. Not required for core product.
DEPLOY_RECORD_TOKEN=your-secure-token-here
