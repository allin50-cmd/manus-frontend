# ============================================================
# DATABASE
# ============================================================
# Neon (or any Postgres) connection string
# Get it free at: https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.eu-west-2.aws.neon.tech/neondb?sslmode=require"

# ============================================================
# SERVER
# ============================================================
PORT=3000
NODE_ENV=production

# Public URL of the deployed app (no trailing slash)
# Azure App Service: https://fineguard-lite.azurewebsites.net
APP_URL="https://fineguard-lite.azurewebsites.net"

# ============================================================
# STRIPE
# ============================================================
# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."

# Price ID for the FineGuard subscription product
# Create at: Stripe Dashboard → Products → Add product
STRIPE_PRICE_ID="price_..."

# Webhook signing secret – from Stripe Dashboard → Webhooks → your endpoint
# Endpoint URL: https://fineguard-lite.azurewebsites.net/api/stripe/webhook
# Events to listen to: checkout.session.completed, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET="whsec_..."

# ============================================================
# COMPANIES HOUSE API
# ============================================================
# Free API key from: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY="your-api-key-here"

# ============================================================
# EMAIL ALERTS (SMTP)
# ============================================================
# Any SMTP provider works. Free options:
#   Gmail:   smtp.gmail.com  port 587  (use an App Password)
#   Brevo:   smtp-relay.brevo.com port 587
#   Mailgun: smtp.mailgun.org port 587

SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="FineGuard <your-email@gmail.com>"

# ============================================================
# SECURITY TOKENS
# ============================================================
# Deployment recording (GitHub Actions → App Service)
# Generate: openssl rand -hex 32
DEPLOY_RECORD_TOKEN="your-deploy-token-here"

# Alert worker runner token (GitHub Actions → /api/internal/run-alerts)
# Generate: openssl rand -hex 32
# Add this as a GitHub Secret named ALERTS_RUNNER_TOKEN
ALERTS_RUNNER_TOKEN="your-alerts-runner-token-here"

# ============================================================
# GITHUB SECRETS TO ADD (Settings → Secrets → Actions)
# ============================================================
# APP_URL            → https://fineguard-lite.azurewebsites.net
# ALERTS_RUNNER_TOKEN → same value as above
