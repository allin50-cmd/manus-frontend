# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/clerkos

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Azure AD B2C (Authentication) ─────────────────────────────────────────────
AZURE_B2C_TENANT_NAME=your-tenant-name
AZURE_B2C_TENANT_ID=your-tenant-id
AZURE_B2C_CLIENT_ID=your-client-id
AZURE_B2C_POLICY=B2C_1_signupsignin

# ── Stripe (Payments) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Companies House API ───────────────────────────────────────────────────────
COMPANIES_HOUSE_API_KEY=your-api-key

# ── Azure Services ────────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://...

# ── Deployment Tracking ───────────────────────────────────────────────────────
DEPLOY_RECORD_TOKEN=your-secret-token
VAULTLINE_API_URL=https://your-api-url.azurecontainerapps.io

# ── ClerkOS Config ────────────────────────────────────────────────────────────
DEFAULT_TENANT_SLUG=alpha
OWNER_OPEN_ID=admin-user
APP_URL=https://your-app-url.com
