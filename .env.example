# ── Database ──────────────────────────────────────────────────────────
# Azure Database for PostgreSQL flexible server recommended
# Format: postgresql://username:password@host:5432/database?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/fineguard?sslmode=require"

# ── Stripe ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Create these price IDs in your Stripe dashboard (£1/mo each)
STRIPE_PRICE_ACCOUNTS_FILING="price_..."
STRIPE_PRICE_CONFIRMATION_STATEMENT="price_..."
STRIPE_PRICE_STRIKE_OFF="price_..."

# ── Stripe Connect ────────────────────────────────────────────────────
# Signing secret for the V2 thin-event webhook destination
# Stripe Dashboard → Developers → Webhooks → V2 destination → signing secret
STRIPE_CONNECT_WEBHOOK_SECRET="whsec_..."
# Signing secret for the standard (V1) subscription webhook endpoint
# Stripe Dashboard → Developers → Webhooks → standard endpoint → signing secret
# (Can reuse STRIPE_WEBHOOK_SECRET if subscriptions share the same endpoint)
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET="whsec_..."
# Price ID for the platform subscription product (what connected accounts pay)
# Create in Stripe Dashboard → Products → Add product → recurring price
STRIPE_CONNECT_SUBSCRIPTION_PRICE_ID="price_..."

# ── Companies House ───────────────────────────────────────────────────
# Free API key: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY="your-api-key"
COMPANIES_HOUSE_BASE_URL="https://api.company-information.service.gov.uk"

# ── App ───────────────────────────────────────────────────────────────
# PUBLIC_APP_URL: used for Stripe success/cancel redirects (your public domain)
# APP_URL: fallback when PUBLIC_APP_URL is not set (Azure hostname)
PUBLIC_APP_URL="https://fineguardpro.com"
APP_URL="https://fineguardpro.azurewebsites.net"
NEXT_PUBLIC_BASE_URL="https://fineguardpro.azurewebsites.net"
NODE_ENV="production"
PORT=8080
WEBSITES_PORT=8080

# ── Deployment tracking (optional) ────────────────────────────────────
# Generate with: openssl rand -hex 32
DEPLOY_RECORD_TOKEN="your-secure-token-here"

# ── Internal API key ──────────────────────────────────────────────────
# Required by: /api/monitoring/*, /api/obligations/*
# Callers must send: x-api-key: <value>
# Generate with: openssl rand -hex 32
MONITORING_API_KEY="your-monitoring-api-key-here"

# ── Dashboard auth ─────────────────────────────────────────────────────
# ADMIN_PASSWORD: the password entered on the /login page
# ADMIN_SESSION_TOKEN: the value stored in the session cookie (separate from password)
# Generate both with: openssl rand -hex 32
ADMIN_PASSWORD="your-secure-admin-password-here"
ADMIN_SESSION_TOKEN="your-secure-session-token-here"

# ── Temporal ──────────────────────────────────────────────────────────
TEMPORAL_ADDRESS="localhost:7233"
TEMPORAL_NAMESPACE="default"
TEMPORAL_TASK_QUEUE="fineguard-compliance"
