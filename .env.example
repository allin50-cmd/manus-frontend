# ── Database ─────────────────────────────────────────────────────────────────
# DATABASE_URL  — pooler URL (used by the running app)
# DIRECT_URL    — direct non-pooler URL (used by migrations only)
#
# Neon (recommended):
#   DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/dbname?sslmode=require"
#   DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"
#
# Supabase (migration path — swap URLs only, no code changes needed):
#   DATABASE_URL="postgresql://postgres.xxx:pass@aws-0-eu-west-2.pooler.supabase.com:6543/postgres"
#   DIRECT_URL="postgresql://postgres.xxx:pass@aws-0-eu-west-2.pooler.supabase.com:5432/postgres"
#
# Local dev:
#   DATABASE_URL="postgresql://postgres:password@localhost:5432/vaultline_dev"
#   (DIRECT_URL not needed locally — falls back to DATABASE_URL automatically)
DATABASE_URL="postgresql://user:password@localhost:5432/vaultline_db"
# DIRECT_URL=""

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Auth (Azure AD B2C) ───────────────────────────────────────────────────────
AZURE_B2C_TENANT_NAME=""
AZURE_B2C_TENANT_ID=""
AZURE_B2C_CLIENT_ID=""
AZURE_B2C_POLICY="B2C_1_signupsignin"
DEFAULT_TENANT_SLUG="demo"
OWNER_OPEN_ID=""

# ── Admin API ─────────────────────────────────────────────────────────────────
# Protects /api/admin/* endpoints. Required header: X-ADMIN-KEY
# Generate with: openssl rand -hex 32
ADMIN_API_KEY="your-admin-api-key-here"

# ── Deployment recording ──────────────────────────────────────────────────────
# Protects /api/deployments/record endpoint. Required header: X-DEPLOY-TOKEN
# Generate with: openssl rand -hex 32
DEPLOY_RECORD_TOKEN="your-secure-token-here"
VAULTLINE_API_URL="https://your-app.azurewebsites.net"
APP_URL="http://localhost:3000"

# ── FineGuard — Companies House ───────────────────────────────────────────────
# REQUIRED for FineGuard compliance checking
# Get your FREE API key at: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY="your-companies-house-api-key-here"

# ── FineGuard — Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID="price_..."

# ── VaultLine — Azure Blob Storage ────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_ACCOUNT=""
AZURE_STORAGE_KEY=""
AZURE_STORAGE_CONTAINER="clerkos-documents"

# ── VaultLine — Azure Service Bus ─────────────────────────────────────────────
AZURE_SERVICE_BUS_CONNECTION_STRING=""
AZURE_SERVICE_BUS_NAMESPACE=""
