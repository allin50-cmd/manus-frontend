# Voice agent runtime
VOICE_AGENT_PORT=8080
AUDIT_LOG_PATH=/data/voice-agent/audit.jsonl
VOICE_AGENT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://manus-frontend-zeta.vercel.app

# Local Docker Compose Postgres
POSTGRES_DB=voice_agent
POSTGRES_USER=voice_agent
POSTGRES_PASSWORD=change-me-local
DATABASE_URL=postgresql://voice_agent:change-me-local@postgres:5432/voice_agent

# Future provider integrations. Leave blank until configured.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
PIPECAT_TRANSPORT=
